  "calculation_formula": {
    "description": "To calculate tax payable for a given taxable income and year: (1) Find the bracket where income falls. (2) Tax = base_tax + (marginal_rate_pct \u00d7 (income \u2212 income_from + 1)). (3) Add Medicare levy (2% of taxable income for most taxpayers). (4) Apply any offsets (LITO, LMITO where applicable).",
    "example": {
      "income_year": "2025-26",
      "taxable_income": 75000,
      "bracket": 3,
      "calculation": "4288 + 0.30 \u00d7 (75000 \u2212 45000) = 4288 + 9000 = $13,288",
      "tax_payable_excl_medicare": 13288,
      "medicare_levy": 1500,
      "total_tax": 14788
    }
  },
